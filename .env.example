DJANGO_SECRET_KEY=replace-me
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,http://127.0.0.1:8001,http://localhost:8001

# Redis.
# Use a different Redis DB/queue than Lossmemory so Celery workers do not
# consume each other's tasks.
REDIS_URL=redis://127.0.0.1:6379/1
CELERY_BROKER_URL=redis://127.0.0.1:6379/1
CELERY_RESULT_BACKEND=redis://127.0.0.1:6379/1
CELERY_TASK_DEFAULT_QUEUE=sqlanalytics
REPORT_STREAM_REDIS_URL=redis://127.0.0.1:6379/2
REPORT_STREAM_BLOCK_MS=5000
REPORT_STREAM_TIMEOUT_SECONDS=120
REPORT_STREAM_SOCKET_TIMEOUT_SECONDS=10

# Django application database. Migrations run here.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sqlanalytics

# Business analytics database. The SQL agent queries this through the sql tool.
ANALYTICS_DATABASE_URL=postgres://postgres:postgres@localhost:5432/travel_erp_uat_qc
ANALYTICS_DATABASE_DIALECT=postgres
ANALYTICS_SQL_TIMEOUT_SECONDS=30
ANALYTICS_SQL_MAX_ROWS=200
ANALYTICS_SQL_MAX_CHARS=12000
ANALYTICS_AGENT_MAX_STEPS=20

GOOGLE_API_KEY=
ANALYTICS_LLM_MODEL=gemini-3.1-flash-lite
ANALYTICS_LLM_PROVIDER_MODEL=google_genai:gemini-3.1-flash-lite

MEMORY_API_BASE_URL=
MEMORY_PROJECT=sqlanalytics
MEMORY_TIMEOUT_SECONDS=10

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
LANGFUSE_TRACE_LANGCHAIN_INTERNALS=false
